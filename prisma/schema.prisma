generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  globalRole    GlobalRole      @default(USER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  ownedTurmas   Turma[]         @relation("TurmaOwner")
  turmaMembers  TurmaMember[]
}
 
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([provider, providerAccountId])
}
 
model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
 
model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@id([identifier, token])
}


model Turma {
  id          String        @id @default(cuid())
  nome        String
  disciplinas String[]      @default([])
  materiais   String[]      @default([])
  ownerId     String        @map("userId")
  owner       User          @relation("TurmaOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     TurmaMember[]
  alunos      Aluno[]
  licoes      Licao[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TurmaMember {
  id        String    @id @default(cuid())
  turmaId   String
  userId    String
  role      TurmaRole
  turma     Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([turmaId, userId])
  @@index([userId])
}


model Aluno {
  id        String   @id @default(cuid())
  nome      String
  turma     Turma    @relation(fields: [turmaId], references: [id])
  turmaId   String
  entregas  EntregaSubLicao[]
}


model Licao {
  id          String      @id @default(cuid())
  dataEnvio   DateTime
  dataEntrega DateTime
  turma       Turma       @relation(fields: [turmaId], references: [id])
  turmaId     String
  subLicoes   SubLicao[]
  createdAt   DateTime    @default(now())
}

model SubLicao {
  id         String   @id @default(cuid())
  disciplina String
  material   String
  descricao  String
  licao      Licao    @relation(fields: [licaoId], references: [id])
  licaoId    String
  entregas   EntregaSubLicao[]
}

enum StatusEntrega {
  FEZ
  NAO_FEZ
  FALTA
}

enum GlobalRole {
  USER
  ADMIN_GLOBAL
}

enum TurmaRole {
  OWNER
  EDITOR
  VIEWER
}

model EntregaSubLicao {
  id          String         @id @default(cuid())
  aluno       Aluno          @relation(fields: [alunoId], references: [id])
  alunoId     String
  subLicao    SubLicao       @relation(fields: [subLicaoId], references: [id])
  subLicaoId  String
  status      StatusEntrega
  updatedAt   DateTime       @updatedAt

  @@unique([alunoId, subLicaoId])
}



